class Solution {
    public boolean isAnagram(String s, String t) {
        int freq[]=new int [26];
        for(char b:s.toCharArray()){
            freq[b-'a']++;

        }
        for(char b:t.toCharArray()){
            freq[b-'a']--;

        }
        for(int i=0;i<freq.length;i++){
            if(freq[i]!=0){
                return false;
            }
        }
      return true;
    }
}
