class Solution {
    int maxSubarraySum(int[] arr) {
        int max=Integer .MIN_VALUE;
        int curr=0;
        for(int i=0;i<arr.length;i++){
            curr=curr+arr[i];
            max=Math.max(max,curr);
            if(curr<0){
                curr=0;
            }
        }
        return max;
    }
}
