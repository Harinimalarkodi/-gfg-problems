class Solution {
    public ArrayList<Integer> findDuplicates(int[] arr) {
        // code here
        Map<Integer,Integer>a=new HashMap<>();
        for(int i:arr){
            a.put(i,a.getOrDefault(i,0)+1);
            
        }
        ArrayList<Integer>ab=new ArrayList<>();
        for(Map.Entry<Integer,Integer>entry:a.entrySet()){
            if(entry.getValue()==2){
                ab.add(entry.getKey());
            }
        }
        return ab;
    }
}
